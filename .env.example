# Flask Configuration
FLASK_ENV=development
SECRET_KEY=dev-key-valtrix-please-change-in-production

# JWT Configuration
JWT_SECRET_KEY=dev-jwt-key-please-change-to-a-strong-secret-2026
JWT_ACCESS_TOKEN_EXPIRES=15
JWT_REFRESH_TOKEN_EXPIRES=7
JWT_COOKIE_SECURE=False

# Database - Supabase PostgreSQL
# Get from: https://app.supabase.com/project/[YOUR_PROJECT_ID]/settings/database
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@[YOUR_SUPABASE_HOST]:5432/postgres

# MercadoPago Configuration
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token

# API Configuration
BASE_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Roblox Configuration
ROBLOX_API_KEY=your_roblox_api_key

# Rate Limiting & Cache
REDIS_URL=redis://localhost:6379
RATELIMIT_DEFAULT=200 per day;50 per hour

# Commission Configuration
COMMISSION_RATE=0.10
